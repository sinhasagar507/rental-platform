{
  "name": "rental-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Rental Listings & Move-in Platform",
  "scripts": {
    "install:all": "cd backend && npm install && cd ../client && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:client\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:client": "cd client && npm run dev",
    "seed": "cd backend && npm run seed",
    "setup": "npm run install:all && npm run seed",
    "build": "cd client && npm run build",
    "start": "cd backend && npm start"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
